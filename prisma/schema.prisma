// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// We do NOT create a User model here because Supabase Auth manages users.
// The userId field in CoffeeLog stores the Supabase Auth user's UUID.

model CoffeeLog {
  id         String   @id @default(uuid())
  userId     String // Supabase Auth user ID
  cafeName   String?
  coffeeType String // e.g., "Cortado", "Latte", "Pour Over"
  rating     Int // 1-5 stars
  notes      String?
  photoUrl   String?
  brewMethod String? // e.g., "Espresso", "Drip", "Cold Brew"
  loggedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Recipe {
  id              String       @id @default(uuid())
  name            String
  description     String
  coffeeType      String // e.g., "Cortado", "Latte"
  brewMethod      String // e.g., "Espresso", "Pour Over"
  difficulty      String // "Easy", "Medium", "Hard"
  prepTimeMinutes Int
  ingredients     String[] // Array of ingredient strings
  instructions    String[] // Array of instruction steps
  equipment       String[] // Required equipment
  imageUrl        String?
  createdAt       DateTime     @default(now())
  steps           RecipeStep[]
}

// Timed steps for the brew timer
model RecipeStep {
  id          String  @id @default(uuid())
  recipeId    String
  recipe      Recipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  order       Int     // Step order (1-based)
  label       String  // e.g., "Bloom", "First Pour", "Wait"
  description String? // Detailed instruction for this step
  durationSec Int     // Duration in seconds (0 = manual advance)

  @@index([recipeId])
}

// User equipment & ingredient profile for recipe matching
model UserProfile {
  id          String   @id @default(uuid())
  userId      String   @unique // Supabase Auth user ID
  equipment   String[] // Equipment the user owns
  ingredients String[] // Ingredients the user has on hand
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}
